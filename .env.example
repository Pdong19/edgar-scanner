# SEC EDGAR requires a User-Agent with contact info (SEC fair access policy)
EDGAR_USER_AGENT="YourName research@yourdomain.com"

# edgartools requires an identity string for SEC API access
EDGAR_IDENTITY="YourName research@yourdomain.com"

# Optional: override default database path (defaults to ./data/sec_filings.db)
# SFI_DB_PATH=/path/to/your/database.db

# Optional: override log directory (defaults to ./logs/)
# SFI_LOG_DIR=/path/to/logs
